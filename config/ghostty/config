font-family = Hack Nerd Font Mono
font-size = 14
adjust-cell-height = 40%
quit-after-last-window-closed = true
theme = dark:tokyonight-moon,light:tokyonight-day

# keybinds to commands aren't supported yet:
# https://github.com/ghostty-org/ghostty/discussions/2353
# keybind = super+,=command:ghostty-config

config-file = macos-config

# shift+enter for newline in Claude code
keybind = shift+enter=text:\x1b\r
# keybind = "cmd+f=write_scrollback_file:open"
