{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "opus",
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": false
  },
  "outputStyle": "engineers-answer",
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/gh-api-readonly.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "plan",
    "additionalDirectories": ["~/code/worktrees"],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/*.envrc.*)",
      "Read(**/secrets/**)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.git/**)",
      "Read(**/.config/gh/**)",
      "Read(**/.git-credentials)",
      "Read(~/.env)",
      "Read(~/.env.*)",
      "Read(~/.envrc)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gitconfig)",
      "Edit(~/.config/git/config)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Edit(**/.local/share/direnv/allow/**)",
      "Grep",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(aws configure export-credentials:*)",
      "Bash(aws * export-credentials:*)",
      "Bash(direnv:*)",
      "Bash(git checkout .)",
      "Bash(git -C * checkout .)",
      "Bash(git checkout -- .)",
      "Bash(git -C * checkout -- .)",
      "Bash(git clean:*)",
      "Bash(git -C * clean:*)",
      "Bash(git push:*)",
      "Bash(git -C * push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git -C * reset --hard:*)",
      "Bash(git restore .)",
      "Bash(git -C * restore .)",
      "Bash(*.env*)",
      "Bash(*.envrc*)",
      "Bash(*/secrets/*)",
      "Bash(*/.aws/*)",
      "Bash(*/.ssh/*)",
      "Bash(*/.gnupg/*)",
      "Bash(*/.config/gh/*)",
      "Bash(*.git-credentials*)",
      "Bash(find * -exec*)",
      "Bash(find * -ok*)",
      "Bash(find * -delete*)",
      "Bash(find * -fprint*)",
      "Bash(find * -fls*)",
      "Bash(find -exec*)",
      "Bash(find -ok*)",
      "Bash(find -delete*)",
      "Bash(find -fprint*)",
      "Bash(find -fls*)"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(rsync:*)",
      "Bash(dd:*)",
      "Bash(rm:*)",
      "WebSearch",
      "mcp__claude_ai_Atlassian__editJiraIssue",
      "mcp__claude_ai_Atlassian__createJiraIssue",
      "mcp__claude_ai_Atlassian__transitionJiraIssue",
      "mcp__claude_ai_Atlassian__addCommentToJiraIssue",
      "mcp__claude_ai_Atlassian__addWorklogToJiraIssue",
      "mcp__claude_ai_Atlassian__createIssueLink",
      "mcp__claude_ai_Atlassian__createConfluencePage",
      "mcp__claude_ai_Atlassian__updateConfluencePage",
      "mcp__claude_ai_Atlassian__createConfluenceFooterComment",
      "mcp__claude_ai_Atlassian__createConfluenceInlineComment",
      "mcp__claude_ai_Atlassian__addTeamworkGraphContext",
      "mcp__claude_ai_Atlassian__createCompassComponent",
      "mcp__claude_ai_Atlassian__createCompassComponentRelationship",
      "mcp__claude_ai_Atlassian__createCompassCustomFieldDefinition"
    ],
    "allow": [
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(command -v:*)",
      "Bash(date)",
      "Bash(git commit:*)",
      "Bash(git -C * commit:*)",
      "Bash(git diff:*)",
      "Bash(git -C * diff:*)",
      "Bash(git log:*)",
      "Bash(git -C * log:*)",
      "Bash(git show:*)",
      "Bash(git -C * show:*)",
      "Bash(git status:*)",
      "Bash(git -C * status:*)",
      "Bash(git rev-parse:*)",
      "Bash(git -C * rev-parse:*)",
      "Bash(git merge-base:*)",
      "Bash(git -C * merge-base:*)",
      "Bash(git check-ignore:*)",
      "Bash(git -C * check-ignore:*)",
      "Bash(git ls-files:*)",
      "Bash(git -C * ls-files:*)",
      "Bash(git symbolic-ref --short HEAD)",
      "Bash(git -C * symbolic-ref --short HEAD)",
      "Bash(just push)",
      "Bash(stylua:*)",
      "Bash(fish_indent:*)",
      "Bash(shfmt:*)",
      "Bash(shellcheck:*)",
      "Bash(prettier:*)",
      "Bash(typos:*)",
      "Bash(yamlfmt:*)",
      "Bash(yamllint:*)",
      "Bash(actionlint:*)",
      "Bash(google-java-format:*)",
      "Bash(claude doctor)",
      "Bash(tree:*)",
      "Bash(tokei:*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com",
        "objects.githubusercontent.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.local/share/nvim",
        "~/.local/state/nvim",
        "~/.cache/nvim"
      ],
      "denyRead": ["~/.env", "~/.envrc"]
    },
    "credentials": {
      "files": [
        {
          "path": "~/.aws",
          "mode": "deny"
        },
        {
          "path": "~/.ssh",
          "mode": "deny"
        },
        {
          "path": "~/.gnupg",
          "mode": "deny"
        },
        {
          "path": "~/.config/gh",
          "mode": "deny"
        },
        {
          "path": "~/.git-credentials",
          "mode": "deny"
        }
      ],
      "envVars": [
        {
          "name": "ANTHROPIC_API_KEY",
          "mode": "deny"
        },
        {
          "name": "GITHUB_TOKEN",
          "mode": "deny"
        }
      ]
    },
    "excludedCommands": [
      "gh *",
      "rcup *",
      "rcdn *",
      "mkrc *",
      "git commit *",
      "git rebase *",
      "git merge *",
      "git cherry-pick *",
      "git revert *",
      "just push",
      "just push *"
    ]
  }
}
