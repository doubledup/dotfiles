{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(wc:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(which:*)",
      "Bash(date)",
      "Bash(git commit:*)",
      "Bash(git -C * commit:*)",
      "Bash(git -C * diff:*)",
      "Bash(git -C * rev-parse:*)",
      "Bash(git -C * show:*)",
      "Bash(git -C * merge-base:*)",
      "Bash(git symbolic-ref --short HEAD)",
      "Bash(git -C * symbolic-ref --short HEAD)",
      "Bash(git -C * log:*)",
      "Bash(git -C * status:*)",
      "Bash(stylua:*)",
      "Bash(fish_indent:*)",
      "Bash(shfmt:*)",
      "Bash(shellcheck:*)",
      "Bash(prettier:*)",
      "Bash(typos:*)",
      "Bash(yamlfmt:*)",
      "Bash(yamllint:*)",
      "Bash(actionlint:*)",
      "Bash(google-java-format:*)",
      "Bash(claude doctor)",
      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(tokei:*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/*.envrc.*)",
      "Read(**/secrets/**)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.git/**)",
      "Edit(**/.local/share/direnv/allow/**)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(aws configure export-credentials:*)",
      "Bash(aws * export-credentials:*)",
      "Bash(direnv allow:*)",
      "Bash(direnv permit:*)",
      "Bash(direnv grant:*)",
      "Bash(direnv edit:*)",
      "Bash(direnv exec:*)",
      "Bash(git checkout .)",
      "Bash(git -C * checkout .)",
      "Bash(git checkout -- .)",
      "Bash(git -C * checkout -- .)",
      "Bash(git clean:*)",
      "Bash(git -C * clean:*)",
      "Bash(git push:*)",
      "Bash(git -C * push:*)",
      "Bash(git reset --hard *)",
      "Bash(git -C * reset --hard *)",
      "Bash(git restore .)",
      "Bash(git -C * restore .)"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(rsync:*)",
      "Bash(dd:*)",
      "Bash(rm:*)",
      "WebSearch",
      "mcp__claude_ai_Atlassian__editJiraIssue",
      "mcp__claude_ai_Atlassian__createJiraIssue",
      "mcp__claude_ai_Atlassian__transitionJiraIssue",
      "mcp__claude_ai_Atlassian__addCommentToJiraIssue",
      "mcp__claude_ai_Atlassian__addWorklogToJiraIssue",
      "mcp__claude_ai_Atlassian__createIssueLink",
      "mcp__claude_ai_Atlassian__createConfluencePage",
      "mcp__claude_ai_Atlassian__updateConfluencePage",
      "mcp__claude_ai_Atlassian__createConfluenceFooterComment",
      "mcp__claude_ai_Atlassian__createConfluenceInlineComment",
      "mcp__claude_ai_Atlassian__addTeamworkGraphContext",
      "mcp__claude_ai_Atlassian__createCompassComponent",
      "mcp__claude_ai_Atlassian__createCompassComponentRelationship",
      "mcp__claude_ai_Atlassian__createCompassCustomFieldDefinition"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/gh-api-readonly.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true
  },
  "outputStyle": "engineers-answer",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com",
        "objects.githubusercontent.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.local/share/nvim",
        "~/.local/state/nvim",
        "~/.cache/nvim"
      ],
      "denyRead": ["~/.env", "~/.envrc"]
    },
    "credentials": {
      "files": [
        {
          "path": "~/.aws",
          "mode": "deny"
        },
        {
          "path": "~/.ssh",
          "mode": "deny"
        }
      ],
      "envVars": [
        {
          "name": "ANTHROPIC_API_KEY",
          "mode": "deny"
        },
        {
          "name": "GITHUB_TOKEN",
          "mode": "deny"
        }
      ]
    },
    "excludedCommands": [
      "gh *",
      "rcup *",
      "rcdn *",
      "mkrc *",
      "git commit *",
      "git rebase *",
      "git merge *",
      "git cherry-pick *",
      "git revert *"
    ]
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": false
}
