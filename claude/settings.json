{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(wc:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(which:*)",
      "Bash(date)",
      "Bash(git diff:*)",
      "Bash(git -C * diff:*)",
      "Bash(git rev-parse:*)",
      "Bash(git -C * rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git -C * show:*)",
      "Bash(git merge-base:*)",
      "Bash(git -C * merge-base:*)",
      "Bash(git symbolic-ref --short HEAD)",
      "Bash(git -C * symbolic-ref --short HEAD)",
      "Bash(git log:*)",
      "Bash(git -C * log:*)",
      "Bash(git status:*)",
      "Bash(git -C * status:*)",
      "Bash(stylua:*)",
      "Bash(fish_indent:*)",
      "Bash(shfmt:*)",
      "Bash(shellcheck:*)",
      "Bash(prettier:*)",
      "Bash(typos:*)",
      "Bash(yamlfmt:*)",
      "Bash(yamllint:*)",
      "Bash(actionlint:*)",
      "Bash(google-java-format:*)",
      "Bash(claude doctor)",
      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(tokei:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/*.envrc.*)",
      "Read(**/secrets/**)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.git/**)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(direnv allow:*)",
      "Bash(direnv permit:*)",
      "Bash(direnv grant:*)",
      "Bash(direnv edit:*)",
      "Bash(direnv exec:*)",
      "Bash(git push:*)",
      "Bash(git -C * push:*)",
      "Bash(git reset --hard *)",
      "Bash(git -C * reset --hard *)",
      "Bash(git checkout .)",
      "Bash(git -C * checkout .)",
      "Bash(git checkout -- .)",
      "Bash(git -C * checkout -- .)",
      "Bash(git restore .)",
      "Bash(git -C * restore .)",
      "Bash(git clean *)",
      "Bash(git -C * clean *)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git -C * commit:*)",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/gh-api-readonly.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true
  },
  "outputStyle": "engineers-answer",
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": false
}
