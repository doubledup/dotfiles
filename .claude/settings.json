{
    "permissions": {
        "defaultMode": "plan",
        "allow": [
            "Bash(just check:*)",
            "Bash(just fmt:*)",
            "Bash(just lint:*)",
            "Bash(just test:*)",
            "Bash(rcup:*)",
            "Bash(rcdn:*)",
            "Bash(lsrc:*)",
            "Bash(nvim --headless:*)",
            "Bash(obsidian help)",
            "Bash(obsidian help *)",
            "Bash(obsidian version)",
            "Bash(obsidian version *)",
            "Bash(obsidian vault)",
            "Bash(obsidian vault *)",
            "Bash(obsidian vaults)",
            "Bash(obsidian vaults *)",
            "Bash(obsidian file *)",
            "Bash(obsidian files)",
            "Bash(obsidian files *)",
            "Bash(obsidian folder *)",
            "Bash(obsidian folders)",
            "Bash(obsidian folders *)",
            "Bash(obsidian read *)",
            "Bash(obsidian search *)",
            "Bash(obsidian search:context *)",
            "Bash(obsidian tags)",
            "Bash(obsidian tags *)",
            "Bash(obsidian tag *)",
            "Bash(obsidian backlinks *)",
            "Bash(obsidian links *)",
            "Bash(obsidian unresolved)",
            "Bash(obsidian unresolved *)",
            "Bash(obsidian orphans)",
            "Bash(obsidian orphans *)",
            "Bash(obsidian deadends)",
            "Bash(obsidian deadends *)",
            "Bash(obsidian outline)",
            "Bash(obsidian outline *)",
            "Bash(obsidian wordcount)",
            "Bash(obsidian wordcount *)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format.sh",
                        "timeout": 30
                    }
                ]
            }
        ]
    }
}
